# DataAutomated.io — .env.example
# Copy to `.env` (which is git-ignored) and fill in local values.
# NEVER commit a real .env. In production these come from AWS Secrets Manager (CLAUDE.md §14, SR-03).
# Placeholders below are non-secret examples only.

# ============================================================
# Database (PostgreSQL 16 + pgvector)
# AUD-02: keep TWO forms of the connection string.
#  - DATABASE_URL      : SQLAlchemy/Alembic dialect URL (has +asyncpg)
#  - DATABASE_DSN      : raw asyncpg DSN (NO +asyncpg prefix) used by the asyncpg pool
# ============================================================
POSTGRES_USER=dataautomated
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=dataautomated
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://dataautomated:change_me_locally@db:5432/dataautomated
DATABASE_DSN=postgresql://dataautomated:change_me_locally@db:5432/dataautomated

# ============================================================
# Auth (custom-JWT backend — D1 default, pending ratification; CLAUDE.md §3, ADR-011)
# ============================================================
JWT_SECRET_KEY=replace_with_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# App-layer credential encryption (SR-04 / AUD-12)
# Per-client data_sources.credentials are AES-256-GCM encrypted at the app layer.
# Local dev: a high-entropy key string. Prod: KMS-backed key from Secrets Manager.
# ============================================================
CREDENTIAL_ENCRYPTION_KEY=replace_with_a_local_dev_key

# ============================================================
# OpenAI (gpt-4o + text-embedding-3-small) — used from P4/P7
# ============================================================
OPENAI_API_KEY=

# ============================================================
# LangSmith observability (NFR-03) — used from P4
# ============================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dataautomated-dev
# Required for org-scoped service keys: without a workspace binding, LangSmith
# returns 403 on workspace endpoints (/sessions, /runs). Find the id via
# GET /api/v1/workspaces or the LangSmith UI workspace settings.
LANGSMITH_WORKSPACE_ID=

# ============================================================
# n8n (orchestration/delivery — P6)
# ============================================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace_with_a_local_password
N8N_WEBHOOK_SECRET=replace_with_a_shared_secret
# Base URL the VoC agent posts churn alerts to (CLAUDE.md §13 Workflow 4).
# Inside docker compose: http://n8n:5678 — leave blank to disable dispatch locally.
N8N_WEBHOOK_URL=
N8N_ENCRYPTION_KEY=replace_with_a_local_n8n_key
N8N_HOST=localhost
N8N_PORT=5678

# ============================================================
# Delivery (Resend) — P6
# ============================================================
RESEND_API_KEY=

# ============================================================
# AWS (production deploy — P9). Local dev leaves these blank.
# ============================================================
AWS_REGION=us-east-1
S3_REPORTS_BUCKET=dataautomated-reports
# Local S3 substitute (minio — added automatically by docker-compose minio service).
# Leave blank/unset in production — real AWS SDK credential chain is used when None.
# When set, path-style addressing is forced (minio has no DNS-wildcard virtual-host support).
S3_ENDPOINT_URL=

# ============================================================
# Frontend
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
