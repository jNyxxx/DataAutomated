# DataAutomated.io — .env.example
# Copy to `.env` (which is git-ignored) and fill in local values.
# NEVER commit a real .env. In production these come from AWS Secrets Manager (CLAUDE.md §14, SR-03).
# Placeholders below are non-secret examples only.

# ============================================================
# Runtime environment (CLAUDE.md §14 security boot guard)
# Set to 'production' in ECS / docker-compose.prod.yml.
# In 'production' mode: placeholder secrets cause boot failure;
# blank webhook secrets cause fail-closed (401) instead of warn-and-allow.
# ============================================================
APP_ENV=development
# Secrets backend: 'env' reads from environment (default, local testing).
# Set to 'aws' when LOCAL-ONLY mode is lifted and ECS task role is configured.
SECRETS_BACKEND=env

# ============================================================
# Database (PostgreSQL 16 + pgvector)
# AUD-02: keep TWO forms of the connection string.
#  - DATABASE_URL      : SQLAlchemy/Alembic dialect URL (has +asyncpg)
#  - DATABASE_DSN      : raw asyncpg DSN (NO +asyncpg prefix) used by the asyncpg pool
# ============================================================
POSTGRES_USER=dataautomated
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=dataautomated
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://dataautomated:change_me_locally@db:5432/dataautomated
DATABASE_DSN=postgresql://dataautomated:change_me_locally@db:5432/dataautomated

# ============================================================
# Auth (custom-JWT backend — D1 default, pending ratification; CLAUDE.md §3, ADR-011)
# ============================================================
JWT_SECRET_KEY=replace_with_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# App-layer credential encryption (SR-04 / AUD-12)
# Per-client data_sources.credentials are AES-256-GCM encrypted at the app layer.
# Local dev: a high-entropy key string. Prod: KMS-backed key from Secrets Manager.
# ============================================================
CREDENTIAL_ENCRYPTION_KEY=replace_with_a_local_dev_key

# ============================================================
# OpenAI (gpt-4o + text-embedding-3-small) — used from P4/P7
# ============================================================
OPENAI_API_KEY=

# ============================================================
# LangSmith observability (NFR-03) — used from P4
# All three agents have @traceable entry points (voc_agent, comp_signal_agent, journey_agent).
# ============================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dataautomated-dev
# Required for org-scoped service keys: without a workspace binding, LangSmith
# returns 403 on workspace endpoints (/sessions, /runs). Find the id via
# GET /api/v1/workspaces or the LangSmith UI workspace settings.
LANGSMITH_WORKSPACE_ID=

# ============================================================
# Sentry error tracking (P11 — env-gated; inert when blank)
# Set in production ECS task env / AWS Secrets Manager. Leave blank locally.
# SDK init is guarded: a blank DSN is a guaranteed no-op (never raises).
# ============================================================
SENTRY_DSN=

# ============================================================
# CloudWatch (deferred — AWS, LOCAL-ONLY mode not yet lifted)
# Log groups / metric filters are configured as IaC when the ECS deploy is activated.
# No local equivalent needed; uvicorn stdout is sufficient for development.
# ============================================================

# ============================================================
# n8n (orchestration/delivery — P6)
# ============================================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace_with_a_local_password
N8N_WEBHOOK_SECRET=replace_with_a_shared_secret
# Base URL the VoC agent posts churn alerts to (CLAUDE.md §13 Workflow 4).
# Inside docker compose: http://n8n:5678 — leave blank to disable dispatch locally.
N8N_WEBHOOK_URL=

# ---- Startup behaviour (Phase 7) ----
# Set to false in production if you run migrations as a separate ECS run-task.
RUN_MIGRATIONS_ON_STARTUP=true
N8N_ENCRYPTION_KEY=replace_with_a_local_n8n_key
N8N_HOST=localhost
N8N_PORT=5678

# ============================================================
# Delivery (Resend) — P6
# ============================================================
RESEND_API_KEY=

# ============================================================
# AWS (production deploy — P9). Local dev leaves these blank.
# ============================================================
AWS_REGION=us-east-1
S3_REPORTS_BUCKET=dataautomated-reports
# IAM credentials. In production these come from the ECS task role (no keys needed).
# For local dev with real S3: fill in; for local dev with minio: use minioadmin/minioadmin.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Local S3 substitute (minio — docker-compose minio service). Leave blank in production.
# When set, path-style addressing is forced (minio has no DNS-wildcard virtual-host support).
S3_ENDPOINT_URL=
# Browser-accessible URL for MinIO presigned links (host-side port). Leave blank in production.
# Example: http://localhost:9000 (when S3_ENDPOINT_URL=http://minio:9000 inside Docker)
S3_PUBLIC_ENDPOINT_URL=
# Explicit S3/MinIO credentials. Leave blank in production (uses AWS credential chain).
# For local MinIO: minioadmin / minioadmin (matches docker-compose MINIO_ROOT_USER/PASSWORD).
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ============================================================
# Slack (operational alerts — WF02 critical signals, WF03 not-ready path)
# Bot token with chat:write scope; channel names are hardcoded in the workflows.
# ============================================================
SLACK_BOT_TOKEN=

# ============================================================
# Frontend
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# Load test (CLAUDE.md §16 Phase 12 — backend/tests/load/run_load_test.py)
# Set these to run authenticated endpoint benchmarks.
# Usage: python backend/tests/load/run_load_test.py
# ============================================================
LOAD_TEST_BASE_URL=http://localhost:8000
LOAD_TEST_EMAIL=
LOAD_TEST_PASSWORD=
# LOAD_TEST_SAMPLES=100        (requests per endpoint per concurrency level)
# LOAD_TEST_CONCURRENCY=10,50,100
# LOAD_TEST_TIMEOUT_S=10
