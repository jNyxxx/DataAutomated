# DataAutomated.io — .gitignore
# SR-03 / OR-06 (CLAUDE.md §14, §17): .env files MUST NEVER be committed.

# ---- Secrets & environment (NEVER COMMIT) ----
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.aws/

# ---- Python (backend) ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# ---- Node / Next.js (frontend) ----
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- n8n (local runtime state — workflows are exported as JSON and committed) ----
n8n/.n8n/
n8n/data/

# ---- Docker / local volumes ----
pgdata/
*.local

# ---- Local engineering artifacts (not part of the §4 source tree) ----
output/

# ---- Editor / OS ----
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
