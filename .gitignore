# DataAutomated.io — .gitignore
# SR-03 / OR-06 (CLAUDE.md §14, §17): .env files MUST NEVER be committed.

# ---- Secrets & environment (NEVER COMMIT) ----
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.aws/
# Root-level AWS/infra policy + secret JSON artifacts (§14 — never commit secrets)
backend-secret.json
ecs-trust.json
n8n-secret.json
temp-phase9-deploy.json
read-dataautomated-secrets.json
reports-bucket-rw.json
new-n8n-td.json
fix_n8n.ps1
setup_n8n.py

# ---- Python (backend) ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# ---- Node / Next.js (frontend) ----
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- n8n (local runtime state — workflows are exported as JSON and committed) ----
n8n/.n8n/
n8n/data/

# ---- Docker / local volumes ----
pgdata/
*.local

# ---- Local engineering artifacts (not part of the §4 source tree) ----
claude-design-export/   # temporary design import source — migration complete; keep off git
output/
# Untracked planning/scratch — keep commits clean. NOTE: scoped patterns only; the project's
# tracked .md docs (README, CLAUDE, MASTER_ROADMAP, architecture docs, …) are intentionally NOT ignored.
SKILL_INSTALLATION_PLAN.md
*.local.md          # local-only markdown notes (e.g. scratch.local.md)
*.plan              # planning scratch
.claude/            # local Claude Code session/plan state, if any lands inside the repo

# ---- Editor / OS ----
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
