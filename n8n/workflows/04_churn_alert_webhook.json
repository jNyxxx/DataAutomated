        "sendBody": true,
        "bodyContentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  from: 'DataAutomated <alerts@dataautomated.io>',\n  to: [$json.body.client_email || 'team@dataautomated.io'],\n  subject: 'Churn Early Warning - Elevated Risk Detected',\n  html: '<h2 style=\"color:#d97706;\">Churn Early Warning</h2><p>An elevated churn risk signal has been detected. This is an early warning - proactive intervention now can prevent churn.</p><table style=\"border-collapse:collapse;width:100%;\"><tr><td style=\"padding:8px;font-weight:bold;\">Client ID:</td><td style=\"padding:8px;\">' + $json.body.client_id + '</td></tr><tr><td style=\"padding:8px;font-weight:bold;\">Churn Risk Score:</td><td style=\"padding:8px;color:#d97706;font-weight:bold;\">' + ($json.body.churn_risk_score * 100).toFixed(1) + '%</td></tr></table><p><strong>Top Themes:</strong></p><pre>' + JSON.stringify($json.body.top_themes, null, 2) + '</pre><p>Churn is possible within <strong>2-4 weeks</strong> if not addressed.</p><p><a href=\"http://localhost:3000/insights\" style=\"background:#d97706;color:white;padding:12px 24px;border-radius:6px;text-decoration:none;\">View Analysis</a></p>'\n}) }}",
        "options": {}
      },
